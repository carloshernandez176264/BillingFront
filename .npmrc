# pnpm configuration for billing-platform-frontend

# Prevent phantom dependencies (packages used but not declared)
public-hoist-pattern[]=*@angular*
public-hoist-pattern[]=*primeng*
public-hoist-pattern[]=*zone.js*

# Strict peer dependencies
strict-peer-dependencies=false
auto-install-peers=true

# Security
audit=true

# Performance
prefer-frozen-lockfile=true
